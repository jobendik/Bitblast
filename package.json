{
  "name": "bitblast",
  "version": "0.1.0",
  "type": "module",
  "description": "BitBlast FPS Game with BITBLAST Integration - Three.js & Yuka AI",
  "repository": "jobendik/BitBlast",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "npm run dev",
    "server": "node server/standalone.cjs",
    "server:standalone": "node server/standalone.cjs",
    "dev:all": "concurrently -n server,client -c magenta,cyan \"npm:server\" \"npm:dev\"",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "author": "jobendik",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dat.gui": "^0.7.13",
    "@types/express": "^5.0.6",
    "@types/three": "^0.181.0",
    "@types/yuka": "^0.7.4",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "concurrently": "^10.0.0",
    "eslint": "^9.17.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dat.gui": "^0.7.9",
    "express": "^5.2.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "three": "^0.181.2",
    "yuka": "^0.7.8"
  }
}
