{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "src/server/**/*",
    "src/types/competitor.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
